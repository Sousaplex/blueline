{
  "designer": {
    "provider": "google",
    "model": "gemini-3.5-flash",
    "apiKeyEnv": "GEMINI_API_KEY"
  },
  "images": {
    "provider": "google",
    "model": "gemini-3.1-flash-image",
    "variantsPerPrompt": 3,
    "apiKeyEnv": "GEMINI_API_KEY"
  },
  "reviewer": {
    "provider": "google",
    "model": "gemini-3.5-flash",
    "maxRounds": 6,
    "apiKeyEnv": "GEMINI_API_KEY"
  },
  "render": {
    "format": "A4",
    "printBackground": true,
    "preferCSSPageSize": true
  },
  "webFetch": {
    "maxFetchesPerRun": 10,
    "maxContentChars": 20000
  }
}
