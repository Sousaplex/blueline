{
  "name": "blueline-app",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "electron:compile": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --external:electron --outdir=dist-electron --format=cjs --out-extension:.js=.cjs",
    "electron:dev": "npm run electron:compile && electron .",
    "electron:app": "npm run build && npm run electron:compile && electron .",
    "electron:smoke": "npm run build && npm run electron:compile && PRESSCHECK_SMOKE=1 electron .",
    "package": "npm run build && npm run electron:compile && electron-builder --mac"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@fontsource-variable/geist": "^5.3.0",
    "@tailwindcss/vite": "^4.3.3",
    "@uiw/react-codemirror": "^4.25.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "lucide-react": "^1.25.0",
    "radix-ui": "^1.6.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "allowScripts": {
    "electron@43.1.1": true,
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true
  },
  "main": "dist-electron/main.cjs",
  "build": {
    "appId": "com.blueline.app",
    "productName": "Blueline",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../toolkit",
        "to": "toolkit",
        "filter": [
          "src/**",
          "package.json",
          "tsconfig.json"
        ]
      },
      {
        "from": "../toolkit/node_modules",
        "to": "toolkit/node_modules"
      },
      {
        "from": "dist",
        "to": "app/dist"
      },
      {
        "from": "../config/providers.example.json",
        "to": "config/providers.example.json"
      }
    ],
    "mac": {
      "target": [
        "dir",
        "dmg"
      ],
      "identity": null
    }
  }
}
